<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Sites.AddFlashCardsList"
             Title="NewPage1">
    <Grid RowDefinitions="*,Auto">

        <VerticalStackLayout Grid.Row="0">
            <Label 
                Text="Welcome to .NET MAUI!"
                VerticalOptions="Center" 
                HorizontalOptions="Center" />
            <Border IsVisible="{Binding IsFormVisible}"
                   WidthRequest="300"
                   HeightRequest="200"
                   Padding="15"
                   Margin="20"
                   VerticalOptions="Center"
                   HorizontalOptions="Center">
                <VerticalStackLayout Spacing="10">
                    <Entry Placeholder="Name of list" Text="{Binding ListCard.Name}"/>
                    <Entry Placeholder="description" Text="{Binding ListCard.Desciption }"/>
                    <Button Text="Save" Command="{Binding SaveCommand}" WidthRequest ="150"/>
                </VerticalStackLayout>
                
            </Border>
        </VerticalStackLayout>

        <Button Grid.Row="1"
                Text="+"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                Margin="0,0,20,20"
                HorizontalOptions="End"
                VerticalOptions="End"
                Command="{Binding ToggleFormCommand}">
        </Button>
    </Grid>
</ContentPage>