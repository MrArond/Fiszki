<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.CardList"
             Title="Zarządzaj Fiszkami">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <!-- Add Card Section -->
        <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,20">
            <Label Text="Dodaj nową fiszkę" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />
            <Entry Placeholder="Nazwa (pojęcie)" Text="{Binding NewCardName}" />
            <Entry Placeholder="Tłumaczenie (definicja)" Text="{Binding NewTranslate}" />
            <Button Text="Dodaj Fiszkę" Command="{Binding AddCardCommand}" />
        </VerticalStackLayout>

        <!-- Cards List -->
        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCardsCommand}">
            <CollectionView ItemsSource="{Binding Cards}">
                <CollectionView.EmptyView>
                    <Label Text="Brak fiszek w tej liście."
                           HorizontalOptions="Center" 
                           VerticalOptions="Center" 
                           FontSize="18" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,5,0,5" CornerRadius="10" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray500}}">
                            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                <Label Text="{Binding CardName}" FontAttributes="Bold" FontSize="18" />
                                <Label Text="-" FontSize="18" />
                                <Label Text="{Binding Translate}" FontSize="18" />
                            </HorizontalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>